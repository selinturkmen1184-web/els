    for(let i=0;i<40;i++){
      const x=150+Math.cos(t*0.02+i*0.5)*120*Math.random();
      const y=100+Math.sin(t*0.03+i*0.7)*80*Math.random();
      ctx.fillStyle=`hsl(${140+i*5},80%,${50+Math.sin(t*0.05+i)*20}%)`;
