<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="description" content="ELLS — Otonom Çay Bahçesi Robotu. Vakum güçlü dört ayaklı robot ile çay hasadını geleceğe taşıyın.">
<meta property="og:title" content="ELLS — Otonom Çay Bahçesi Robotu">
<meta property="og:description" content="Türkiye'nin ilk otonom çay hasat robotu. Daha akıllı, daha hızlı, daha yeşil.">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<title>ELLS — Otonom Çay Bahçesi Robotu</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/@phosphor-icons/web"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:#0d2319; --surface:rgba(20,45,30,0.4); --surface-hover:rgba(30,60,40,0.6);
  --border:rgba(255,255,255,0.1); --border-glow:rgba(74,222,128,0.3);
  --text:#f8fafc; --muted:#a7f3d0; --purple:#a78bfa; --green:#4ade80; --red:#fca5a5;
  --blur:blur(20px);
}
body.light-mode {
  --bg:#f0faf4; --surface:rgba(255,255,255,0.7); --surface-hover:rgba(255,255,255,0.9);
  --border:rgba(0,0,0,0.1); --border-glow:rgba(16,185,129,0.3);
  --text:#0d2319; --muted:#065f46; --purple:#7c3aed; --green:#059669; --red:#dc2626;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;overflow-x:hidden;}
img{max-width:100%;height:auto;display:block;}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;
  background-image:radial-gradient(circle at 15% 0%,rgba(74,222,128,0.15) 0%,transparent 60%),
    radial-gradient(circle at 85% 100%,rgba(167,139,250,0.1) 0%,transparent 50%),
    linear-gradient(135deg,#091a13 0%,#103322 100%);
  background-attachment:fixed;line-height:1.6;transition:background 0.4s,color 0.4s;}
body.light-mode{background-image:radial-gradient(circle at 15% 0%,rgba(16,185,129,0.1) 0%,transparent 60%),
  linear-gradient(135deg,#f0faf4 0%,#e0f2eb 100%);}
.glass{background:var(--surface);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border:1px solid var(--border);border-radius:16px;}
.gradient-text{background:linear-gradient(90deg,#d8b4fe,var(--green));-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-decoration:none;}
.hero-title .typewriter-cursor{display:none;}
.container{max-width:1400px;margin:0 auto;padding:0 2rem;width:100%;}
section{scroll-margin-top:80px;}

/* PROGRESS BAR */
#progress-bar{position:fixed;top:0;left:0;height:3px;width:0%;
  background:linear-gradient(90deg,var(--purple),var(--green));z-index:9999;transition:width 0.1s;}

/* COOKIE */
#cookie-banner{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);
  background:rgba(9,26,19,0.95);backdrop-filter:var(--blur);border:1px solid var(--border-glow);
  border-radius:20px;padding:1.2rem 2rem;display:flex;align-items:center;gap:1.5rem;
  z-index:9000;max-width:700px;width:calc(100% - 2rem);flex-wrap:wrap;
  transition:opacity 0.4s,transform 0.4s;}
#cookie-banner.hidden{opacity:0;transform:translateX(-50%) translateY(20px);pointer-events:none;}
#cookie-banner p{font-size:0.85rem;color:var(--muted);flex:1;min-width:200px;}
#cookie-banner p a{color:var(--green);text-decoration:none;}
.cookie-btns{display:flex;gap:0.6rem;flex-shrink:0;}
.btn-cookie-ok{background:var(--green);color:#0d2319;border:none;padding:0.5rem 1.2rem;border-radius:20px;font-size:0.82rem;font-weight:700;cursor:pointer;}
.btn-cookie-no{background:transparent;color:var(--muted);border:1px solid var(--border);padding:0.5rem 1.2rem;border-radius:20px;font-size:0.82rem;cursor:pointer;}

/* CHAT BUTTON */
#chat-btn{position:fixed;bottom:2rem;right:2rem;min-width:64px;height:56px;border-radius:16px;
  background:linear-gradient(135deg,#10b981,#059669);color:white;border:none;cursor:none;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
  font-size:1.3rem;box-shadow:0 4px 20px rgba(16,185,129,0.4);z-index:8000;transition:all 0.3s;
  padding:0 0.8rem;}
#chat-btn:hover{transform:translateY(-3px);box-shadow:0 6px 30px rgba(16,185,129,0.6);}
#chat-badge{position:absolute;top:-5px;right:-5px;width:18px;height:18px;border-radius:50%;
  background:#ef4444;color:white;font-size:0.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;}
.fab-label{font-size:0.6rem;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;line-height:1;display:block;}

/* THEME TOGGLE */
#theme-toggle{position:fixed;bottom:2rem;left:2rem;min-width:64px;height:56px;border-radius:16px;
  background:var(--surface);border:1px solid var(--border-glow);color:var(--green);
  font-size:1.2rem;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
  cursor:none;z-index:8000;transition:all 0.3s;backdrop-filter:var(--blur);padding:0 0.8rem;}
#theme-toggle:hover{transform:translateY(-3px);background:var(--surface-hover);}

/* BACK TO TOP */
#back-to-top{position:fixed;bottom:2rem;right:5.5rem;min-width:64px;height:56px;border-radius:16px;
  background:var(--surface);border:1px solid var(--border-glow);color:var(--green);
  font-size:1.2rem;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
  cursor:none;transition:all 0.3s;opacity:0;pointer-events:none;z-index:999;text-decoration:none;
  backdrop-filter:var(--blur);padding:0 0.8rem;}
#back-to-top.visible{opacity:1;pointer-events:all;}
#back-to-top:hover{transform:translateY(-3px);background:var(--surface-hover);}

/* NAV */
#chat-modal{position:fixed;bottom:6.5rem;right:2rem;width:340px;max-width:calc(100vw - 2rem);
  border-radius:20px;z-index:8001;overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,0.4);
  transition:all 0.3s;transform:scale(0.95) translateY(20px);opacity:0;pointer-events:none;}
#chat-modal.open{transform:scale(1) translateY(0);opacity:1;pointer-events:all;}
.chat-header{background:linear-gradient(135deg,#10b981,#059669);padding:1.2rem 1.5rem;
  display:flex;align-items:center;gap:1rem;color:white;}
.chat-avatar{width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.2);
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;}
.chat-header h4{font-size:0.95rem;font-weight:600;}
.chat-header p{font-size:0.75rem;opacity:0.85;}
.chat-online{width:8px;height:8px;border-radius:50%;background:#86efac;display:inline-block;margin-right:4px;}
.chat-body{background:rgba(9,26,19,0.97);padding:1.2rem;display:flex;flex-direction:column;gap:0.8rem;max-height:280px;overflow-y:auto;}
.chat-bubble{padding:0.7rem 1rem;border-radius:14px;font-size:0.85rem;max-width:85%;line-height:1.5;}
.chat-bubble.bot{background:rgba(74,222,128,0.12);border:1px solid rgba(74,222,128,0.2);color:var(--text);align-self:flex-start;border-bottom-left-radius:4px;}
.chat-bubble.user{background:linear-gradient(135deg,#10b981,#059669);color:white;align-self:flex-end;border-bottom-right-radius:4px;}
.chat-quick{display:flex;flex-wrap:wrap;gap:0.4rem;padding:0.8rem 1.2rem;background:rgba(9,26,19,0.97);border-top:1px solid var(--border);}
.quick-btn{padding:0.4rem 0.9rem;border-radius:20px;border:1px solid var(--border-glow);
  background:transparent;color:var(--green);font-size:0.75rem;cursor:pointer;transition:all 0.2s;}
.quick-btn:hover{background:rgba(74,222,128,0.1);}
.chat-input-row{display:flex;gap:0.5rem;padding:0.8rem 1.2rem;background:rgba(9,26,19,0.97);border-top:1px solid var(--border);}
.chat-input{flex:1;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:20px;
  padding:0.5rem 1rem;color:var(--text);font-size:0.85rem;outline:none;}
.chat-input:focus{border-color:var(--green);}
.chat-send{width:36px;height:36px;border-radius:50%;background:var(--green);border:none;
  color:#0d2319;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}

/* CHAT MODAL */
nav{position:fixed;top:0;width:100%;z-index:1000;padding:1rem 0;transition:all 0.4s;border-bottom:1px solid transparent;}
nav.scrolled{background:rgba(9,26,19,0.95);backdrop-filter:var(--blur);border-bottom:1px solid var(--border);padding:0.6rem 0;}
body.light-mode nav.scrolled{background:rgba(240,250,244,0.95);}
.nav-content{display:flex;justify-content:space-between;align-items:center;gap:1rem;}
.logo{font-family:'Outfit',sans-serif;font-size:1.6rem;font-weight:800;letter-spacing:4px;
  display:flex;align-items:center;gap:8px;text-decoration:none;color:var(--text);flex-shrink:0;}
.logo img{height:42px;width:auto;transition:filter 0.3s;}
.logo:hover img{filter:drop-shadow(0 0 10px rgba(74,222,128,0.7));}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{color:var(--muted);text-decoration:none;font-size:0.9rem;font-weight:500;transition:all 0.3s;position:relative;}
.nav-links a::after{content:'';position:absolute;width:0;height:2px;bottom:-5px;left:0;background:var(--green);transition:width 0.3s;}
.nav-links a:hover{color:var(--text);}
.nav-links a:hover::after{width:100%;}
.nav-right{display:flex;align-items:center;gap:0.8rem;flex-shrink:0;}
.lang-switcher{display:flex;align-items:center;background:rgba(255,255,255,0.06);
  border:1px solid var(--border);border-radius:30px;padding:3px;gap:2px;}
.lang-btn{padding:4px 12px;border-radius:24px;font-size:0.8rem;font-weight:700;letter-spacing:1px;
  cursor:pointer;border:none;background:transparent;color:var(--muted);transition:all 0.3s;}
.lang-btn.active{background:var(--green);color:#0d2319;box-shadow:0 0 12px rgba(74,222,128,0.4);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:5px;background:none;border:none;}
.hamburger span{display:block;width:24px;height:2px;background:var(--text);transition:all 0.3s;border-radius:2px;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.mobile-menu{display:none;position:fixed;inset:0;background:rgba(9,26,19,0.98);
  backdrop-filter:var(--blur);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:2rem;}
.mobile-menu.open{display:flex;}
.mobile-menu a{color:var(--text);text-decoration:none;font-family:'Outfit',sans-serif;font-size:1.8rem;font-weight:600;transition:color 0.3s;}
.mobile-menu a:hover{color:var(--green);}
.mobile-lang{display:flex;gap:1rem;margin-top:1rem;}
.btn{padding:0.65rem 1.6rem;border-radius:30px;text-decoration:none;font-weight:500;font-size:0.9rem;
  display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:all 0.3s;cursor:pointer;border:none;white-space:nowrap;}
.btn-demo{background:linear-gradient(135deg,#10b981,#059669);color:white;
  box-shadow:0 0 20px rgba(16,185,129,0.3);border:1px solid rgba(16,185,129,0.5);}
.btn-demo:hover{box-shadow:0 0 30px rgba(16,185,129,0.6);transform:translateY(-2px);}
.btn-outline{background:var(--surface);border:1px solid var(--border);color:var(--text);}
.btn-outline:hover{background:var(--surface-hover);transform:translateY(-2px);}
.reveal{opacity:0;transform:translateY(40px);transition:all 0.8s cubic-bezier(0.5,0,0,1);}
.reveal.active{opacity:1;transform:translateY(0);}

/* HERO */
.hero{padding:10rem 0 5rem;min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;}
.hero-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.08;z-index:0;pointer-events:none;}
.hero-grid{display:grid;grid-template-columns:1.2fr 0.8fr;gap:4rem;align-items:center;width:100%;position:relative;z-index:1;}
.hero-title{font-family:'Outfit',sans-serif;font-size:7rem;font-weight:800;line-height:1;margin-bottom:0.5rem;letter-spacing:-2px;}
.hero-subtitle{font-family:'Outfit',sans-serif;font-size:1.1rem;letter-spacing:6px;color:var(--muted);margin-bottom:2rem;text-transform:uppercase;}
.hero-text{font-size:2rem;font-weight:300;line-height:1.3;margin-bottom:2.5rem;}
.hero-text span:first-child{color:var(--purple);font-weight:400;}
.hero-text span:last-child{color:var(--green);font-weight:400;}
.hero-actions{display:flex;gap:1rem;margin-bottom:3rem;flex-wrap:wrap;}
.hero-metrics{display:flex;flex-wrap:wrap;gap:1.5rem;padding:1.2rem 1.5rem;border-radius:20px;width:100%;}
.metric-item{display:flex;align-items:center;gap:12px;}
.metric-icon{font-size:1.6rem;color:var(--green);}
.metric-info h4{font-size:1.1rem;font-weight:600;}
.metric-info p{font-size:0.82rem;color:var(--muted);}
.particle{position:absolute;border-radius:50%;background:var(--green);opacity:0.4;animation:floatParticle linear infinite;pointer-events:none;}

/* ROBOT CARD */
.robot-container{width:100%;aspect-ratio:3/4;border-radius:24px;position:relative;
  display:flex;align-items:center;justify-content:center;
  border:1px solid var(--border-glow);box-shadow:inset 0 0 60px rgba(74,222,128,0.1),0 20px 50px rgba(0,0,0,0.4);
  overflow:hidden;background:linear-gradient(180deg,rgba(20,45,30,0.2) 0%,rgba(10,25,15,0.8) 100%);}
.robot-bg-glow{position:absolute;width:400px;height:400px;
  background:radial-gradient(circle,rgba(74,222,128,0.15) 0%,transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-50%);z-index:0;animation:pulseGlow 4s infinite alternate;}
.grid-lines{position:absolute;inset:0;z-index:1;opacity:0.15;
  background-image:linear-gradient(var(--green) 1px,transparent 1px),linear-gradient(90deg,var(--green) 1px,transparent 1px);
  background-size:30px 30px;}
.robot-blueprint{position:relative;z-index:2;text-align:center;padding:1.5rem;width:85%;}
.robot-blueprint img{width:160px;height:auto;margin:0 auto 1.2rem;filter:drop-shadow(0 0 25px rgba(74,222,128,0.5));}
.robot-blueprint h3{font-family:'Outfit',sans-serif;letter-spacing:2px;margin-bottom:1.2rem;color:var(--green);font-size:0.95rem;}
.specs-list{text-align:left;background:rgba(0,0,0,0.3);padding:1.2rem;border-radius:16px;border:1px solid rgba(255,255,255,0.1);}
.specs-list div{padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:0.85rem;color:var(--muted);}
.specs-list div:last-child{border-bottom:none;}
.specs-list span.num{color:var(--purple);font-weight:600;margin-right:8px;font-family:'Outfit',sans-serif;}
.ai-badge{position:absolute;bottom:20px;right:20px;width:80px;height:80px;border-radius:50%;
  border:1px solid var(--green);display:flex;flex-direction:column;justify-content:center;align-items:center;
  color:var(--green);font-size:0.65rem;text-align:center;background:rgba(10,25,15,0.8);
  backdrop-filter:blur(8px);box-shadow:0 0 20px rgba(74,222,128,0.2);
  animation:float 4s ease-in-out infinite;z-index:3;text-transform:uppercase;letter-spacing:1px;}
.ai-badge i{font-size:1.3rem;margin-bottom:2px;}
.scan-line{position:absolute;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,rgba(74,222,128,0.6),transparent);z-index:4;animation:scanMove 3s linear infinite;}

/* SECTION HEADER */
.section-header{text-align:center;margin-bottom:3.5rem;}
.section-header h2{font-family:'Outfit',sans-serif;font-size:2.4rem;letter-spacing:2px;}
.section-header h2 span{color:var(--green);}
.section-header p{color:var(--muted);margin-top:10px;}

/* SYSTEM FLOW */
.system-flow{padding:6rem 0;}
.flow-container{display:flex;justify-content:space-between;align-items:flex-start;position:relative;gap:1rem;}
.flow-container::before{content:'';position:absolute;top:40px;left:5%;right:5%;height:2px;
  background:linear-gradient(90deg,var(--purple),var(--green));z-index:0;opacity:0.3;}
.flow-step{flex:1;text-align:center;position:relative;z-index:1;padding:0 0.8rem;}
.flow-icon{width:80px;height:80px;border-radius:50%;margin:0 auto 1.2rem;background:var(--bg);
  border:2px solid var(--border);display:flex;justify-content:center;align-items:center;
  font-size:1.8rem;color:var(--text);transition:all 0.4s;}
.flow-step:hover .flow-icon{border-color:var(--green);color:var(--green);box-shadow:0 0 30px rgba(74,222,128,0.3);transform:scale(1.1);}
.flow-step h3{font-size:1rem;margin-bottom:0.4rem;}
.flow-step p{font-size:0.82rem;color:var(--muted);}

/* LIVE COUNTER */
.live-section{padding:4rem 0;background:rgba(74,222,128,0.03);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.live-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:center;}
.live-card{padding:2rem;}
.live-label{font-size:0.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:2px;margin-bottom:0.5rem;}
.live-number{font-family:'Outfit',sans-serif;font-size:3rem;font-weight:800;color:var(--green);line-height:1;}
.live-sub{font-size:0.75rem;color:var(--muted);margin-top:4px;}
.live-dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--green);
  margin-right:6px;animation:livePulse 1.5s ease-in-out infinite;}

/* SIMULATOR */
.simulator-section{padding:6rem 0;}
.simulator-section *{opacity:1 !important;transform:none !important;}
.simulator-card{padding:2.5rem;border-radius:24px;background:var(--surface);backdrop-filter:var(--blur);border:1px solid var(--border);}
.simulator-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;}
.sim-controls{display:flex;flex-direction:column;gap:2rem;}
.sim-label{font-size:0.82rem;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:1px;display:block;}
.sim-value{font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:700;color:var(--green);margin-bottom:8px;display:block;}
input[type=range]{width:100%;-webkit-appearance:none;height:4px;border-radius:4px;outline:none;cursor:pointer;
  background:linear-gradient(90deg,var(--green) var(--val,50%),rgba(255,255,255,0.1) var(--val,50%));}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;
  background:var(--green);box-shadow:0 0 10px rgba(74,222,128,0.5);cursor:pointer;}
.sim-results{display:flex;flex-direction:column;gap:1.2rem;}
.result-card{padding:1.3rem;border-radius:16px;background:rgba(0,0,0,0.2);border:1px solid var(--border);display:flex;align-items:center;gap:1.2rem;}
.result-card i{font-size:2.2rem;color:var(--green);flex-shrink:0;}
.result-card h3{font-family:'Outfit',sans-serif;font-size:1.8rem;font-weight:800;line-height:1;}
.result-card p{color:var(--muted);font-size:0.82rem;margin-top:3px;}

/* CO2 RESULT */
.co2-card{background:rgba(167,139,250,0.08);border-color:rgba(167,139,250,0.3);}
.co2-card i{color:var(--purple);}
.co2-card h3{color:var(--purple);}

/* FEATURES */
.features{padding:4rem 0 6rem;}
.features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
.feature-card{padding:1.8rem;transition:all 0.4s;border-top:1px solid rgba(255,255,255,0.15);}
.feature-card:hover{transform:translateY(-10px);border-color:var(--green);box-shadow:0 15px 40px rgba(74,222,128,0.15);background:var(--surface-hover);}
.feature-icon{width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,0.05);
  display:flex;justify-content:center;align-items:center;font-size:1.8rem;margin-bottom:1.2rem;border:1px solid var(--border);}
.c-purple{color:var(--purple);}
.c-green{color:var(--green);}

/* COMPARISON */
.comparison{padding:6rem 0;text-align:center;}
.comp-container{display:flex;justify-content:center;align-items:stretch;gap:3rem;position:relative;}
.comp-box{flex:1;padding:3rem 2.5rem;text-align:left;position:relative;overflow:hidden;border-radius:24px;min-width:0;}
.comp-box::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;}
.problem-box::before{background:linear-gradient(90deg,transparent,var(--red),transparent);}
.solution-box::before{background:linear-gradient(90deg,transparent,var(--green),transparent);}
.comp-box h3{font-size:1.5rem;margin-bottom:2rem;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.problem-box h3{color:var(--red);}
.solution-box h3{color:var(--green);}
.comp-list{list-style:none;display:flex;flex-direction:column;gap:1.4rem;}
.comp-list li{display:flex;align-items:center;gap:1rem;font-size:1.05rem;color:var(--muted);}
.comp-list li i{font-size:1.4rem;flex-shrink:0;}
.problem-box .comp-list li i{color:var(--red);}
.solution-box .comp-list li{color:var(--text);}
.solution-box .comp-list li i{color:var(--green);}
.comp-center{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
  width:80px;height:80px;border-radius:50%;background:var(--bg);border:1px solid var(--border);
  display:flex;justify-content:center;align-items:center;font-size:2rem;color:var(--green);
  box-shadow:0 0 40px rgba(74,222,128,0.3);z-index:10;}

/* STATS */
.stats{padding:4rem 0 6rem;border-bottom:1px solid var(--border);}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;}
.stat-card{display:flex;align-items:center;justify-content:center;gap:1.2rem;
  padding:2rem 1.5rem;text-align:left;transition:transform 0.3s;}
.stat-card:hover{transform:scale(1.05);}
.stat-card i{font-size:2.5rem;color:var(--green);filter:drop-shadow(0 0 10px rgba(74,222,128,0.4));flex-shrink:0;}
.stat-info h2{font-size:2.5rem;font-family:'Outfit',sans-serif;font-weight:800;line-height:1;}
.stat-info p{color:var(--muted);font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;margin-top:4px;}

/* SPECS TABLE */
.tech-specs{padding:6rem 0;}
.specs-table-wrap{overflow-x:auto;margin-top:2rem;border-radius:20px;-webkit-overflow-scrolling:touch;}
.specs-table{width:100%;min-width:480px;border-collapse:collapse;}
.specs-table th,.specs-table td{padding:1rem 1.3rem;text-align:left;border-bottom:1px solid var(--border);}
.specs-table th{background:rgba(74,222,128,0.08);color:var(--green);font-family:'Outfit',sans-serif;
  font-weight:600;letter-spacing:1px;font-size:0.85rem;text-transform:uppercase;white-space:nowrap;}
.specs-table td{color:var(--muted);font-size:0.9rem;}
.specs-table td:first-child{color:var(--text);font-weight:500;}
.specs-table tr:hover td{background:rgba(255,255,255,0.03);}
.spec-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:0.75rem;font-weight:600;white-space:nowrap;}
.badge-green{background:rgba(74,222,128,0.15);color:var(--green);border:1px solid rgba(74,222,128,0.3);}
.badge-purple{background:rgba(167,139,250,0.15);color:var(--purple);border:1px solid rgba(167,139,250,0.3);}

/* TIMELINE */
.timeline{padding:6rem 0;}
.timeline-container{position:relative;max-width:800px;margin:3rem auto 0;}
.timeline-container::before{content:'';position:absolute;left:50%;top:0;bottom:0;width:2px;
  background:linear-gradient(180deg,var(--purple),var(--green));opacity:0.3;transform:translateX(-50%);}
.timeline-item{display:flex;gap:2rem;align-items:center;margin-bottom:2.5rem;}
.timeline-item:nth-child(odd){flex-direction:row-reverse;}
.timeline-item:nth-child(odd) .timeline-content{text-align:right;}
.timeline-content{flex:1;min-width:0;padding:1.3rem;border-radius:16px;background:var(--surface);border:1px solid var(--border);transition:all 0.3s;}
.timeline-content:hover{border-color:var(--border-glow);}
.timeline-dot{width:14px;height:14px;border-radius:50%;background:var(--green);
  border:3px solid var(--bg);box-shadow:0 0 15px rgba(74,222,128,0.5);flex-shrink:0;position:relative;z-index:1;}
.timeline-year{font-family:'Outfit',sans-serif;font-size:0.82rem;color:var(--green);font-weight:700;margin-bottom:4px;letter-spacing:1px;}
.timeline-content h3{font-size:1rem;margin-bottom:4px;}
.timeline-content p{font-size:0.85rem;color:var(--muted);}

/* FAQ */
.faq{padding:6rem 0;}
.faq-list{max-width:800px;margin:2.5rem auto 0;display:flex;flex-direction:column;gap:1rem;}
.faq-item{border-radius:16px;border:1px solid var(--border);overflow:hidden;transition:border-color 0.3s;}
.faq-item.open{border-color:var(--border-glow);}
.faq-question{padding:1.3rem 1.5rem;display:flex;justify-content:space-between;align-items:center;
  cursor:pointer;font-size:1rem;font-weight:500;background:var(--surface);transition:background 0.3s;gap:1rem;}
.faq-question:hover{background:var(--surface-hover);}
.faq-question i{color:var(--green);font-size:1.2rem;transition:transform 0.4s;flex-shrink:0;}
.faq-item.open .faq-question i{transform:rotate(45deg);}
.faq-answer{max-height:0;overflow:hidden;transition:max-height 0.4s ease,padding 0.4s ease;
  background:rgba(0,0,0,0.15);color:var(--muted);font-size:0.92rem;line-height:1.7;padding:0 1.5rem;}
.faq-item.open .faq-answer{max-height:400px;padding:1.3rem 1.5rem;}

/* CTA */
.cta-section{padding:7rem 0;text-align:center;}
.cta-box{padding:4rem 2.5rem;border-radius:32px;position:relative;overflow:hidden;
  background:linear-gradient(135deg,rgba(74,222,128,0.08),rgba(167,139,250,0.08));border:1px solid rgba(74,222,128,0.2);}
.cta-box::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;
  background:radial-gradient(circle at center,rgba(74,222,128,0.05) 0%,transparent 60%);animation:rotateBg 15s linear infinite;}
.cta-box h2{font-family:'Outfit',sans-serif;font-size:3rem;font-weight:800;margin-bottom:1.2rem;position:relative;z-index:1;}
.cta-box p{font-size:1.1rem;color:var(--muted);margin-bottom:2.5rem;position:relative;z-index:1;max-width:600px;margin-left:auto;margin-right:auto;}
.cta-buttons{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap;position:relative;z-index:1;}
.btn-large{padding:1rem 2.5rem;font-size:1rem;border-radius:50px;}

/* NEWSLETTER */
.newsletter{padding:3.5rem 0;border-top:1px solid var(--border);}
.newsletter-inner{display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;}
.newsletter h3{font-family:'Outfit',sans-serif;font-size:1.4rem;}
.newsletter p{color:var(--muted);font-size:0.88rem;margin-top:4px;}
.newsletter-form{display:flex;gap:0.8rem;flex-wrap:wrap;}
.newsletter-input{padding:0.7rem 1.3rem;border-radius:30px;border:1px solid var(--border);
  background:var(--surface);color:var(--text);font-size:0.9rem;width:260px;max-width:100%;outline:none;transition:border-color 0.3s;}
.newsletter-input:focus{border-color:var(--green);}
.newsletter-input::placeholder{color:rgba(167,240,195,0.4);}

/* FOOTER */
footer{padding:4rem 0 2rem;background:#091a13;}
body.light-mode footer{background:#e0f2eb;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem;}
.footer-brand p{color:var(--muted);font-size:0.88rem;margin-top:1rem;line-height:1.7;}
.footer-col h4{font-family:'Outfit',sans-serif;font-weight:600;margin-bottom:1rem;
  color:var(--green);font-size:0.85rem;letter-spacing:1px;text-transform:uppercase;}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:0.6rem;}
.footer-col ul li a{color:var(--muted);text-decoration:none;font-size:0.88rem;transition:color 0.3s;}
.footer-col ul li a:hover{color:var(--text);}
.footer-bottom{border-top:1px solid var(--border);padding-top:2rem;display:flex;
  justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;}
.footer-bottom p{color:var(--muted);font-size:0.82rem;}
.social-links{display:flex;gap:0.8rem;}
.social-link{width:38px;height:38px;border-radius:50%;border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;color:var(--muted);
  text-decoration:none;font-size:1rem;transition:all 0.3s;}
.social-link:hover{border-color:var(--green);color:var(--green);}

/* ANIMATIONS */
@keyframes bodyFadeIn{from{opacity:0;}to{opacity:1;}}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
@keyframes pulseGlow{0%{opacity:0.3;transform:translate(-50%,-50%) scale(0.8);}100%{opacity:0.8;transform:translate(-50%,-50%) scale(1.1);}}
@keyframes scanMove{0%{top:-2px;}100%{top:102%;}}
@keyframes floatParticle{0%{opacity:0;transform:translateY(0);}10%{opacity:0.4;}90%{opacity:0.2;}100%{opacity:0;transform:translateY(-400px);}}
@keyframes rotateBg{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
@keyframes chatPulse{0%,100%{box-shadow:0 4px 20px rgba(16,185,129,0.4);}50%{box-shadow:0 4px 30px rgba(16,185,129,0.7),0 0 0 8px rgba(16,185,129,0.1);}}
@keyframes livePulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.8);}}
@keyframes preloaderPulse{0%,100%{transform:scale(1);filter:drop-shadow(0 0 10px rgba(74,222,128,0.3));}50%{transform:scale(1.05);filter:drop-shadow(0 0 25px rgba(74,222,128,0.6));}}

/* RESPONSIVE */
@media(max-width:1024px){
  .hero-grid{grid-template-columns:1fr;gap:3rem;text-align:center;}
  .hero-actions{justify-content:center;}
  .hero-metrics{justify-content:flex-start;}
  .metric-item{border-left:none !important;padding-left:0 !important;}
  .features-grid{grid-template-columns:repeat(2,1fr);}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
  .flow-container{flex-direction:column;gap:2rem;align-items:center;}
  .flow-container::before{display:none;}
  .nav-links{display:none;}
  .hamburger{display:flex;}
  .footer-grid{grid-template-columns:1fr 1fr;}
  .simulator-grid{grid-template-columns:1fr;}
  .robot-container{max-width:380px;margin:0 auto;aspect-ratio:1/1;}
  .live-grid{grid-template-columns:1fr;}
  .comp-container{flex-direction:column;gap:1rem;}
  .comp-center{position:static;transform:none;margin:0 auto;}
}
@media(max-width:768px){
  .container{padding:0 1rem;}
  .hero{padding:7rem 0 3rem;min-height:auto;}
  .hero-title{font-size:4.5rem;letter-spacing:-1px;}
  .hero-text{font-size:1.5rem;margin-bottom:1.5rem;}
  .hero-actions{flex-direction:column;width:100%;gap:0.8rem;margin-bottom:2rem;}
  .hero-actions .btn{width:100%;}
  .hero-metrics{flex-direction:column;gap:1rem;padding:1rem;}
  .robot-container{max-width:100%;aspect-ratio:4/3;}
  .robot-blueprint img{width:120px;}
  .nav-right .btn-demo{padding:0.5rem 0.9rem;font-size:0.78rem;}
  .lang-btn{padding:3px 9px;font-size:0.75rem;}
  .system-flow,.simulator-section,.features,.comparison,.stats,.tech-specs,.timeline,.faq,.cta-section,.live-section{padding:3rem 0;}
  .section-header{margin-bottom:2rem;}
  .section-header h2{font-size:1.7rem;}
  .flow-icon{width:60px;height:60px;font-size:1.5rem;}
  .simulator-card{padding:1.2rem;}
  .simulator-grid{grid-template-columns:1fr !important;gap:1.5rem;}
  .result-card{padding:1rem;gap:0.8rem;}
  .result-card h3{font-size:1.5rem;}
  .features-grid{grid-template-columns:1fr;gap:0.8rem;}
  .feature-card{padding:1.3rem;}
  .comp-box{padding:1.8rem 1.3rem;}
  .comp-box h3{font-size:1.2rem;margin-bottom:1.3rem;}
  .stats-grid{grid-template-columns:repeat(2,1fr);gap:0.8rem;}
  .stat-card{padding:1.3rem 0.8rem;flex-direction:column;text-align:center;gap:0.6rem;}
  .stat-card i{font-size:2rem;}
  .stat-info h2{font-size:2rem;}
  .timeline-container::before{left:7px;}
  .timeline-item{flex-direction:column !important;gap:0.8rem;margin-bottom:1.8rem;padding-left:1.5rem;position:relative;}
  .timeline-item:nth-child(odd) .timeline-content{text-align:left;}
  .timeline-dot{position:absolute;left:0;top:6px;}
  .timeline-content{flex:none;width:100%;}
  .faq-question{padding:1rem 1.2rem;font-size:0.92rem;}
  .faq-answer,.faq-item.open .faq-answer{padding-left:1.2rem;padding-right:1.2rem;}
  .cta-box{padding:2.5rem 1.2rem;}
  .cta-box h2{font-size:1.8rem;}
  .cta-buttons{flex-direction:column;width:100%;gap:0.8rem;}
  .cta-buttons .btn{width:100%;}
  .btn-large{padding:0.85rem 1.5rem;font-size:0.95rem;}
  .newsletter-inner{flex-direction:column;align-items:stretch;gap:1.2rem;}
  .newsletter-form{flex-direction:column;}
  .newsletter-input{width:100%;}
  .newsletter-form .btn{width:100%;}
  .footer-grid{grid-template-columns:1fr;gap:1.8rem;}
  .footer-bottom{flex-direction:column;text-align:center;gap:0.5rem;}
  .social-links{justify-content:center;}
  #chat-btn{width:50px;height:50px;font-size:1.4rem;}
  #chat-modal{right:1rem;width:calc(100vw - 2rem);}
  #theme-toggle{bottom:1.5rem;left:1rem;}
  #back-to-top{bottom:1.5rem;right:4.5rem;}
  #cookie-banner{flex-direction:column;gap:1rem;padding:1rem 1.2rem;}
  .live-number{font-size:2.2rem;}
}
@media(max-width:400px){
  .hero-title{font-size:3.5rem;}
  .hero-text{font-size:1.25rem;}
  .section-header h2{font-size:1.4rem;}
  .stat-info h2{font-size:1.7rem;}
}


/* ── TOAST BİLDİRİMLERİ ── */
#toast-container {
  position: fixed; bottom: 5.5rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; gap: 0.6rem; z-index: 88888;
  align-items: center; pointer-events: none;
}
.toast {
  padding: 0.8rem 1.6rem; border-radius: 30px; font-size: 0.88rem; font-weight: 500;
  display: flex; align-items: center; gap: 0.6rem; pointer-events: all;
  backdrop-filter: var(--blur); animation: toastIn 0.4s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 8px 30px rgba(0,0,0,0.3); white-space: nowrap;
}
.toast-success { background: rgba(16,185,129,0.15); border: 1px solid rgba(74,222,128,0.4); color: var(--green); }
.toast-info    { background: rgba(167,139,250,0.15); border: 1px solid rgba(167,139,250,0.4); color: var(--purple); }
.toast-warning { background: rgba(251,191,36,0.15);  border: 1px solid rgba(251,191,36,0.4);  color: #fbbf24; }
.toast.hide    { animation: toastOut 0.3s ease forwards; }
@keyframes toastIn  { from { opacity:0; transform:translateY(20px) scale(0.9); } to { opacity:1; transform:translateY(0) scale(1); } }
@keyframes toastOut { from { opacity:1; transform:translateY(0) scale(1); }   to { opacity:0; transform:translateY(-10px) scale(0.9); } }

/* ── 3D ROBOT KARTII ── */
.robot3d-section { padding: 6rem 0; }
.robot3d-wrapper {
  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
}
.robot3d-scene {
  perspective: 1000px; width: 100%; max-width: 420px; margin: 0 auto;
  aspect-ratio: 1; cursor: none;
}
.robot3d-card {
  width: 100%; height: 100%; position: relative; transform-style: preserve-3d;
  transition: transform 0.1s ease; border-radius: 24px;
}
.robot3d-front, .robot3d-back {
  position: absolute; inset: 0; border-radius: 24px; backface-visibility: hidden;
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.robot3d-front {
  background: linear-gradient(135deg, rgba(20,45,30,0.9), rgba(10,25,15,0.95));
  border: 1px solid var(--border-glow);
  box-shadow: 0 25px 60px rgba(0,0,0,0.5), inset 0 0 60px rgba(74,222,128,0.05);
}
.robot3d-back {
  background: linear-gradient(135deg, rgba(74,222,128,0.1), rgba(167,139,250,0.1));
  border: 1px solid rgba(167,139,250,0.3);
  transform: rotateY(180deg);
  flex-direction: column; gap: 1rem; padding: 2rem; text-align: center;
}
.robot3d-back h3 { font-family: 'Outfit', sans-serif; font-size: 1.4rem; color: var(--green); }
.robot3d-back p  { color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
.robot3d-scene.flipped .robot3d-card { transform: rotateY(180deg) !important; }
.robot3d-glow {
  position: absolute; inset: 0; border-radius: 24px; pointer-events: none; z-index: 2;
  background: radial-gradient(circle at var(--mx,50%) var(--my,50%), rgba(74,222,128,0.12) 0%, transparent 60%);
}
.robot3d-grid-lines {
  position: absolute; inset: 0; z-index: 0; opacity: 0.08; border-radius: 24px;
  background-image: linear-gradient(var(--green) 1px,transparent 1px), linear-gradient(90deg,var(--green) 1px,transparent 1px);
  background-size: 28px 28px;
}
.robot3d-img { width: 75%; position: relative; z-index: 1; filter: drop-shadow(0 0 30px rgba(74,222,128,0.4)); }
.robot3d-badge {
  position: absolute; top: 16px; right: 16px; z-index: 3;
  background: rgba(74,222,128,0.15); border: 1px solid var(--border-glow);
  border-radius: 20px; padding: 5px 12px; font-size: 0.72rem; color: var(--green);
  font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
}
.robot3d-hint {
  text-align: center; margin-top: 1rem; font-size: 0.8rem; color: var(--muted);
  display: flex; align-items: center; justify-content: center; gap: 0.4rem;
}
.robot3d-info { display: flex; flex-direction: column; gap: 1.5rem; }
.robot3d-info h2 { font-family: 'Outfit', sans-serif; font-size: 2rem; font-weight: 800; }
.robot3d-info h2 span { color: var(--green); }
.robot3d-info p { color: var(--muted); line-height: 1.7; }
.robot3d-specs { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem; }
.r3d-spec { padding: 1rem; border-radius: 14px; background: var(--surface); border: 1px solid var(--border); text-align: center; }
.r3d-spec h4 { font-family: 'Outfit', sans-serif; font-size: 1.4rem; font-weight: 800; color: var(--green); }
.r3d-spec p  { font-size: 0.75rem; color: var(--muted); margin-top: 3px; }
.flip-btn {
  padding: 0.7rem 1.8rem; border-radius: 30px; border: 1px solid var(--border-glow);
  background: transparent; color: var(--green); font-size: 0.9rem; font-weight: 500;
  cursor: none; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px;
  width: fit-content;
}
.flip-btn:hover { background: rgba(74,222,128,0.1); transform: translateY(-2px); }

/* ── MATRİX YAĞMUR ── */
#matrix-canvas {
  position: fixed; inset: 0; z-index: -1; opacity: 0; pointer-events: none;
  transition: opacity 1s ease;
}
#matrix-canvas.active { opacity: 0.07; }
body.light-mode #matrix-canvas { opacity: 0 !important; }
#matrix-toggle {
  position: fixed; bottom: 2rem; left: 5.5rem; min-width: 64px; height: 56px;
  border-radius: 16px; background: var(--surface); border: 1px solid var(--border-glow);
  color: var(--green); font-size: 1.1rem; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 2px;
  cursor: none; z-index: 8000; transition: all 0.3s;
  backdrop-filter: var(--blur); padding: 0 0.8rem;
}
#matrix-toggle:hover { transform: translateY(-3px); background: var(--surface-hover); }
#matrix-toggle.active { background: rgba(74,222,128,0.2); border-color: var(--green); }

/* ── TÜRKİYE HARİTASI ── */
.map-section { padding: 6rem 0; }
.map-container {
  position: relative; border-radius: 24px; overflow: hidden; padding: 3rem;
  background: var(--surface); backdrop-filter: var(--blur); border: 1px solid var(--border);
  min-height: 420px; display: flex; align-items: center; justify-content: center;
}
#turkey-map { width: 100%; max-width: 780px; }
#turkey-map path {
  fill: rgba(74,222,128,0.08); stroke: rgba(74,222,128,0.25); stroke-width: 0.8px;
  transition: fill 0.3s, stroke 0.3s; cursor: none;
}
#turkey-map path:hover { fill: rgba(74,222,128,0.22); stroke: var(--green); }
#turkey-map path.pilot { fill: rgba(74,222,128,0.3); stroke: var(--green); stroke-width: 1.5px; animation: mapPulse 2s ease-in-out infinite; }
.map-pin {
  position: absolute; transform: translate(-50%, -100%);
  display: flex; flex-direction: column; align-items: center; z-index: 10;
}
.map-pin-dot {
  width: 14px; height: 14px; border-radius: 50%; background: var(--green);
  border: 2px solid #0d2319; box-shadow: 0 0 12px rgba(74,222,128,0.6);
  animation: mapPulse 1.8s ease-in-out infinite;
}
.map-pin-label {
  background: rgba(9,26,19,0.9); border: 1px solid var(--border-glow);
  border-radius: 8px; padding: 4px 10px; font-size: 0.72rem; color: var(--green);
  font-weight: 600; white-space: nowrap; margin-bottom: 5px; backdrop-filter: blur(8px);
}
.map-legend {
  display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;
  margin-top: 1.5rem;
}
.legend-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: var(--muted); }
.legend-dot { width: 10px; height: 10px; border-radius: 50%; }
.legend-dot.pilot { background: var(--green); box-shadow: 0 0 8px rgba(74,222,128,0.5); }
.legend-dot.planned { background: var(--purple); box-shadow: 0 0 8px rgba(167,139,250,0.5); }
@keyframes mapPulse { 0%,100%{opacity:1;} 50%{opacity:0.5;} }

@media(max-width:768px) {
  .robot3d-wrapper { grid-template-columns: 1fr; gap: 2rem; }
  .robot3d-scene { max-width: 300px; }
  .robot3d-specs { grid-template-columns: 1fr 1fr; }
  .map-container { padding: 1.5rem; min-height: 280px; }
  #chat-btn{width:auto;min-width:56px;height:50px;bottom:1rem;right:1rem;border-radius:14px;}
  #theme-toggle{width:auto;min-width:56px;height:50px;bottom:1rem;left:1rem;border-radius:14px;}
  #matrix-toggle{width:auto;min-width:56px;height:50px;bottom:1rem;left:5rem;border-radius:14px;}
  #back-to-top{width:auto;min-width:56px;height:50px;bottom:1rem;right:5rem;border-radius:14px;}
}

/* ══ TYPEWRITER ══ */
.typewriter-cursor{display:inline-block;width:4px;height:0.85em;background:var(--green);margin-left:4px;vertical-align:middle;animation:blink 0.9s step-end infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
/* ══ WAVE DIVIDER ══ */
.wave-divider{position:relative;height:70px;overflow:hidden;margin:0;line-height:0;}
.wave-divider svg{position:absolute;bottom:0;width:100%;height:100%;}
.wave-divider.flip{transform:scaleY(-1);}
/* ══ GRADIENT BORDER ══ */
.grad-border-wrap{position:relative;border-radius:22px;padding:2px;background:conic-gradient(from 0deg,var(--green),var(--purple),var(--green));animation:rotateBorderAnim 4s linear infinite;}
.grad-border-inner{background:var(--bg);border-radius:20px;padding:2rem;height:100%;}
@keyframes rotateBorderAnim{0%{filter:hue-rotate(0deg);}100%{filter:hue-rotate(360deg);}}
/* ══ RIPPLE ══ */
.ripple{position:absolute;border-radius:50%;transform:scale(0);animation:rippleAnim 0.6s linear;background:rgba(255,255,255,0.22);pointer-events:none;}
@keyframes rippleAnim{to{transform:scale(5);opacity:0;}}
/* ══ FLOATING LEAVES ══ */
.leaf-particle{position:fixed;pointer-events:none;z-index:1;animation:leafFall linear infinite;opacity:0;user-select:none;font-size:1rem;}
@keyframes leafFall{0%{transform:translateY(-20px) rotate(0deg) translateX(0);opacity:0;}10%{opacity:0.7;}50%{transform:translateY(50vh) rotate(360deg) translateX(30px);}90%{opacity:0.3;}100%{transform:translateY(105vh) rotate(720deg) translateX(-20px);opacity:0;}}
/* ══ NEON PULSE ══ */
.btn-demo{animation:neonPulse 3s ease-in-out infinite;}
@keyframes neonPulse{0%,100%{box-shadow:0 0 20px rgba(16,185,129,0.3),0 0 40px rgba(16,185,129,0.1);}50%{box-shadow:0 0 35px rgba(16,185,129,0.65),0 0 70px rgba(16,185,129,0.25);}}
/* ══ HORIZONTAL SCROLL ══ */
.hscroll-section{padding:5rem 0;overflow:hidden;}
.hscroll-track{display:flex;gap:1.5rem;padding:1rem 2rem;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;cursor:grab;}
.hscroll-track::-webkit-scrollbar{display:none;}
.hscroll-track:active{cursor:grabbing;}
.hscroll-card{flex:0 0 300px;scroll-snap-align:start;padding:2rem;border-radius:20px;background:var(--surface);border:1px solid var(--border);transition:all 0.3s;position:relative;overflow:hidden;}
.hscroll-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(74,222,128,0.06),transparent);opacity:0;transition:opacity 0.3s;}
.hscroll-card:hover{transform:translateY(-6px);border-color:var(--border-glow);}
.hscroll-card:hover::before{opacity:1;}
.hscroll-num{font-family:'Outfit',sans-serif;font-size:3.5rem;font-weight:800;color:rgba(74,222,128,0.12);line-height:1;margin-bottom:0.5rem;}
.hscroll-icon{font-size:2rem;color:var(--green);margin-bottom:1rem;}
.hscroll-card h3{font-size:1.05rem;margin-bottom:0.4rem;}
.hscroll-card p{font-size:0.83rem;color:var(--muted);line-height:1.6;}
.hscroll-arrows{display:flex;gap:0.8rem;justify-content:center;margin-top:1.5rem;}
.hscroll-arrow{width:40px;height:40px;border-radius:50%;border:1px solid var(--border-glow);background:transparent;color:var(--green);font-size:1.1rem;cursor:none;display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.hscroll-arrow:hover{background:rgba(74,222,128,0.12);transform:scale(1.1);}
/* ══ BIG TYPOGRAPHY ══ */
.bigtype-section{padding:5rem 0;overflow:hidden;text-align:center;border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.bigtype-marquee{display:flex;gap:3rem;width:max-content;animation:marqueeScroll 22s linear infinite;}
.bigtype-marquee:hover{animation-play-state:paused;}
.bigtype-word{font-family:'Outfit',sans-serif;font-size:clamp(3rem,7vw,6.5rem);font-weight:800;letter-spacing:-2px;white-space:nowrap;color:transparent;-webkit-text-stroke:1.5px rgba(74,222,128,0.22);transition:all 0.3s;cursor:default;}
.bigtype-word:hover{-webkit-text-stroke:0px;color:var(--green);text-shadow:0 0 40px rgba(74,222,128,0.4);}
.bigtype-word.filled{color:var(--green);-webkit-text-stroke:0px;}
.bigtype-sep{font-family:'Outfit',sans-serif;font-size:clamp(3rem,7vw,6.5rem);font-weight:800;color:rgba(167,139,250,0.18);white-space:nowrap;}
@keyframes marqueeScroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}
/* ══ İKON ANİMASYONLARI ══ */
.flow-step:hover .flow-icon i{animation:iconBounce 0.5s ease;}
.feature-card:hover .feature-icon i{animation:iconSpin 0.6s ease;}
@keyframes iconBounce{0%,100%{transform:translateY(0);}40%{transform:translateY(-8px);}70%{transform:translateY(-4px);}}
@keyframes iconSpin{0%{transform:rotate(0);}100%{transform:rotate(360deg);}}
/* ══ SCROLL-ROBOT ══ */
.scroll-robot-section{padding:5rem 0;}
.scroll-robot-wrap{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;}
.scroll-robot-img{width:100%;max-width:360px;margin:0 auto;filter:drop-shadow(0 0 30px rgba(74,222,128,0.35));transition:transform 0.1s linear;will-change:transform;}
.scroll-robot-steps{display:flex;flex-direction:column;gap:1.2rem;}
.scroll-step{padding:1.4rem;border-radius:16px;border:1px solid var(--border);transition:all 0.4s;opacity:0.35;}
.scroll-step.active{opacity:1;border-color:var(--border-glow);background:var(--surface);box-shadow:0 0 30px rgba(74,222,128,0.08);}
.scroll-step h3{display:flex;align-items:center;gap:0.8rem;margin-bottom:0.3rem;font-size:1rem;}
.scroll-step h3 span{font-family:'Outfit',sans-serif;color:var(--green);font-size:1.2rem;font-weight:800;}
.scroll-step p{font-size:0.83rem;color:var(--muted);}
/* ══ NOISE TEXTURE ══ */
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:99996;opacity:0.35;}
body.light-mode::after{opacity:0.1;}
/* ══ GLASSMORPHISM UPGRADE ══ */
.glass{background:rgba(20,45,30,0.5);backdrop-filter:blur(28px) saturate(1.6);-webkit-backdrop-filter:blur(28px) saturate(1.6);border:1px solid rgba(255,255,255,0.13);box-shadow:0 8px 32px rgba(0,0,0,0.22),inset 0 1px 0 rgba(255,255,255,0.07);}
body.light-mode .glass{background:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.7);box-shadow:0 8px 32px rgba(0,0,0,0.07),inset 0 1px 0 rgba(255,255,255,0.95);}
/* ══ KART 3D HOVER ══ */
.feature-card:hover{transform:translateY(-10px) perspective(600px) rotateX(4deg);}
.stat-card:hover{transform:scale(1.05) perspective(600px) rotateY(-3deg);}
.hscroll-card:hover{transform:translateY(-6px) perspective(600px) rotateX(3deg);}
/* mobile */
@media(max-width:768px){
  .scroll-robot-wrap{grid-template-columns:1fr;}
  .scroll-robot-img{max-width:200px;}
  .bigtype-word,.bigtype-sep{font-size:clamp(2rem,9vw,3.5rem);}
  .hscroll-card{flex:0 0 250px;}
}

*, *::before, *::after { cursor: none !important; }
#cursor {
  position: fixed; width: 12px; height: 12px; border-radius: 50%;
  background: var(--green); pointer-events: none; z-index: 99999;
  transform: translate(-50%,-50%); transition: width 0.2s, height 0.2s, opacity 0.2s, background 0.2s;
  mix-blend-mode: difference;
}
#cursor-ring {
  position: fixed; width: 36px; height: 36px; border-radius: 50%;
  border: 1.5px solid rgba(74,222,128,0.6); pointer-events: none; z-index: 99998;
  transform: translate(-50%,-50%); transition: width 0.35s cubic-bezier(0.25,0.46,0.45,0.94),
    height 0.35s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.3s, border-color 0.3s;
}
#cursor.hovering { width: 20px; height: 20px; background: var(--purple); }
#cursor-ring.hovering { width: 56px; height: 56px; border-color: rgba(167,139,250,0.5); }
#cursor.clicking { width: 8px; height: 8px; }
#cursor-ring.clicking { width: 28px; height: 28px; }
@media (hover: none) { #cursor, #cursor-ring { display: none; } * { cursor: auto !important; } }

/* ── SAYFA GEÇİŞ ANİMASYONU ── */
#page-transition {
  position: fixed; inset: 0; z-index: 99990; pointer-events: none;
  display: flex; flex-direction: column;
}
.pt-stripe {
  flex: 1; background: var(--green); transform: scaleX(0); transform-origin: left;
  transition: transform 0.4s cubic-bezier(0.77,0,0.175,1);
}
.pt-stripe:nth-child(even) { background: #059669; transform-origin: right; }
body.transitioning .pt-stripe { transform: scaleX(1); }

/* ── PARALLAX ── */
.hero { overflow: hidden; }
.hero-parallax {
  position: absolute; inset: -15%; width: 130%; height: 130%;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(74,222,128,0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(167,139,250,0.06) 0%, transparent 50%);
  z-index: 0; will-change: transform;
}
.hero-grid { position: relative; z-index: 1; }

/* ── SCROLL RENK DEĞİŞİMİ (section glow) ── */
.section-glow {
  position: relative;
}
.section-glow::before {
  content: ''; position: absolute; inset: 0; opacity: 0;
  transition: opacity 0.8s ease; pointer-events: none; border-radius: inherit;
  background: radial-gradient(ellipse at 50% 0%, rgba(74,222,128,0.04) 0%, transparent 70%);
}
.section-glow.glow-active::before { opacity: 1; }

/* ── CURSOR TRAIL ── */
.cursor-trail {
  position: fixed; width: 5px; height: 5px; border-radius: 50%;
  background: rgba(74,222,128,0.4); pointer-events: none; z-index: 99997;
  transform: translate(-50%,-50%); transition: opacity 0.5s;
}

/* ══ TEAM SECTION ══ */
.team-section{padding:6rem 0;}
.team-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;margin-top:3rem;max-width:800px;margin-left:auto;margin-right:auto;}
.team-card{padding:2.5rem 2rem;border-radius:24px;background:var(--surface);border:1px solid var(--border);text-align:center;transition:all 0.4s;position:relative;overflow:hidden;}
.team-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--green),var(--purple));}
.team-card:hover{transform:translateY(-8px);border-color:var(--border-glow);box-shadow:0 20px 50px rgba(74,222,128,0.1);}
.team-avatar{width:80px;height:80px;border-radius:50%;margin:0 auto 1.2rem;background:linear-gradient(135deg,rgba(74,222,128,0.2),rgba(167,139,250,0.2));border:2px solid var(--border-glow);display:flex;align-items:center;justify-content:center;font-family:'Outfit',sans-serif;font-size:2rem;font-weight:800;color:var(--green);}
.team-name{font-size:1.1rem;font-weight:600;margin-bottom:0.3rem;}
.team-role{font-size:0.82rem;color:var(--green);font-weight:500;margin-bottom:1rem;text-transform:uppercase;letter-spacing:1px;}
.team-bio{font-size:0.85rem;color:var(--muted);line-height:1.6;}
.team-socials{display:flex;gap:0.6rem;justify-content:center;margin-top:1.2rem;}
.team-social{width:32px;height:32px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:0.9rem;text-decoration:none;transition:all 0.3s;}
.team-social:hover{border-color:var(--green);color:var(--green);}





/* ══ CONTACT FORM ══ */
.contact-section{padding:6rem 0;}
.contact-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:4rem;align-items:start;}
.contact-info h2{font-family:'Outfit',sans-serif;font-size:2rem;font-weight:800;margin-bottom:1rem;}
.contact-info h2 span{color:var(--green);}
.contact-info p{color:var(--muted);line-height:1.7;margin-bottom:2rem;}
.contact-detail{display:flex;align-items:center;gap:1rem;margin-bottom:1.2rem;color:var(--muted);font-size:0.92rem;}
.contact-detail i{font-size:1.4rem;color:var(--green);flex-shrink:0;}
.contact-form{display:flex;flex-direction:column;gap:1.2rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.form-group{display:flex;flex-direction:column;gap:0.4rem;position:relative;}
.form-group label{font-size:0.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-weight:500;}
.form-input{padding:0.85rem 1.2rem;border-radius:14px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:0.92rem;outline:none;transition:all 0.3s;font-family:'Inter',sans-serif;width:100%;}
.form-input:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(74,222,128,0.1);}
.form-input::placeholder{color:rgba(167,240,195,0.3);}
select.form-input option{background:#0d2319;color:var(--text);}
textarea.form-input{resize:vertical;min-height:120px;}
.form-submit{padding:1rem 2rem;border-radius:30px;background:linear-gradient(135deg,#10b981,#059669);color:white;border:none;font-size:1rem;font-weight:600;cursor:none;transition:all 0.3s;display:flex;align-items:center;justify-content:center;gap:0.6rem;}
.form-submit:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(16,185,129,0.4);}
.form-success{display:none;text-align:center;padding:2rem;color:var(--green);}
.form-success i{font-size:3rem;margin-bottom:1rem;display:block;}

/* ══ DEMO MODAL ══ */
#demo-modal{position:fixed;inset:0;z-index:88000;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity 0.3s;}
#demo-modal.open{opacity:1;pointer-events:all;}
#demo-modal-bg{position:absolute;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(8px);}
#demo-modal-box{position:relative;z-index:1;width:100%;max-width:520px;border-radius:28px;padding:2.5rem;background:rgba(9,26,19,0.98);border:1px solid var(--border-glow);box-shadow:0 30px 80px rgba(0,0,0,0.5);transform:scale(0.95);transition:transform 0.3s;}
#demo-modal.open #demo-modal-box{transform:scale(1);}
.modal-close{position:absolute;top:1.2rem;right:1.2rem;width:36px;height:36px;border-radius:50%;border:1px solid var(--border);background:transparent;color:var(--muted);font-size:1.2rem;cursor:none;display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.modal-close:hover{border-color:var(--red);color:var(--red);}
.modal-title{font-family:'Outfit',sans-serif;font-size:1.6rem;font-weight:800;margin-bottom:0.5rem;}
.modal-title span{color:var(--green);}
.modal-sub{color:var(--muted);font-size:0.88rem;margin-bottom:2rem;}

/* ══ CHART SECTION ══ */
.chart-section{padding:6rem 0;}
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:3rem;}
.chart-card{padding:2rem;border-radius:20px;background:var(--surface);border:1px solid var(--border);}
.chart-card h3{font-size:1rem;margin-bottom:1.5rem;color:var(--text);}
.chart-card canvas{width:100%!important;}

/* ══ AI LEAF DETECTOR ══ */
.leafai-section{padding:6rem 0;}
.leafai-wrap{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;margin-top:3rem;}
.leafai-canvas-wrap{border-radius:20px;overflow:hidden;border:1px solid var(--border-glow);position:relative;background:#0a1a10;}
#leafCanvas{width:100%;display:block;cursor:none;}
.leafai-info{display:flex;flex-direction:column;gap:1.5rem;}
.leafai-stat{padding:1.2rem;border-radius:14px;background:var(--surface);border:1px solid var(--border);}
.leafai-stat-label{font-size:0.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:0.3rem;}
.leafai-stat-value{font-family:'Outfit',sans-serif;font-size:1.8rem;font-weight:800;color:var(--green);}
.leafai-bar{height:6px;border-radius:3px;background:rgba(255,255,255,0.08);margin-top:0.5rem;overflow:hidden;}
.leafai-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--green),var(--purple));transition:width 0.5s ease;}
.leafai-controls{display:flex;gap:0.8rem;flex-wrap:wrap;}
.leafai-btn{padding:0.6rem 1.4rem;border-radius:20px;border:1px solid var(--border-glow);background:transparent;color:var(--green);font-size:0.85rem;cursor:none;transition:all 0.3s;}
.leafai-btn:hover,.leafai-btn.active{background:rgba(74,222,128,0.12);border-color:var(--green);}

/* ══ KVKK / PWA ══ */
#pwa-banner{position:fixed;bottom:6rem;left:50%;transform:translateX(-50%);background:rgba(9,26,19,0.96);border:1px solid var(--border-glow);border-radius:20px;padding:1rem 1.5rem;display:flex;align-items:center;gap:1rem;z-index:8888;max-width:380px;width:calc(100% - 2rem);transition:all 0.4s;box-shadow:0 8px 30px rgba(0,0,0,0.3);}
#pwa-banner.hidden{opacity:0;pointer-events:none;transform:translateX(-50%) translateY(20px);}
#pwa-banner i{font-size:2rem;color:var(--green);flex-shrink:0;}
#pwa-banner p{font-size:0.82rem;color:var(--muted);flex:1;}
#pwa-banner p strong{color:var(--text);display:block;margin-bottom:2px;}
.pwa-btn{padding:0.5rem 1rem;border-radius:20px;background:var(--green);color:#0d2319;border:none;font-size:0.8rem;font-weight:700;cursor:none;white-space:nowrap;}

/* ══ EASTER EGG ══ */
#easter-egg{position:fixed;inset:0;z-index:999999;background:rgba(0,0,0,0.95);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2rem;opacity:0;pointer-events:none;transition:opacity 0.5s;}
#easter-egg.show{opacity:1;pointer-events:all;}
#easter-egg h2{font-family:'Outfit',sans-serif;font-size:3rem;font-weight:800;background:linear-gradient(90deg,var(--green),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center;}
#easter-egg p{color:var(--muted);text-align:center;max-width:400px;}
#egg-close{padding:0.7rem 2rem;border-radius:30px;background:var(--green);color:#0d2319;border:none;font-weight:700;cursor:none;font-size:0.95rem;}
#egg-canvas{border-radius:16px;}

/* ══ KONAMI ══ */
#konami-banner{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);z-index:999998;background:linear-gradient(135deg,var(--green),var(--purple));border-radius:20px;padding:2rem 3rem;text-align:center;transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1);box-shadow:0 0 80px rgba(74,222,128,0.4);}
#konami-banner.show{transform:translate(-50%,-50%) scale(1);}
#konami-banner h3{font-family:'Outfit',sans-serif;font-size:1.8rem;font-weight:800;color:#0d2319;margin-bottom:0.5rem;}
#konami-banner p{color:rgba(9,26,19,0.8);font-size:0.9rem;}

/* responsive */
@media(max-width:768px){
  .team-grid,.awards-grid{grid-template-columns:1fr;}
  .contact-grid{grid-template-columns:1fr;}
  .form-row{grid-template-columns:1fr;}
  .chart-grid{grid-template-columns:1fr;}
  .leafai-wrap{grid-template-columns:1fr;}
  #pwa-banner{max-width:calc(100% - 2rem);}
}

/* ══ SPOTLIGHT ══ */
#spotlight {
  position: fixed; width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(circle, rgba(74,222,128,0.06) 0%, transparent 70%);
  pointer-events: none; z-index: 0; transform: translate(-50%,-50%);
  transition: left 0.15s ease, top 0.15s ease; mix-blend-mode: screen;
}

/* ══ BLOB MORPHİNG ══ */
#blob-bg {
  position: fixed; top: 50%; left: 50%; width: 600px; height: 600px;
  transform: translate(-50%,-50%); z-index: -1; pointer-events: none; opacity: 0.35;
}
#blob-bg svg { width: 100%; height: 100%; animation: blobRotate 20s linear infinite; }
@keyframes blobRotate { to { transform: rotate(360deg); } }

/* ══ SCROLL PROGRESS HALKA ══ */
#scroll-ring {
  position: fixed; bottom: 5.5rem; right: 1.5rem; width: 44px; height: 44px;
  z-index: 8000; pointer-events: none;
}
#scroll-ring svg { transform: rotate(-90deg); }
#scroll-ring circle.track { fill: none; stroke: rgba(255,255,255,0.1); stroke-width: 3; }
#scroll-ring circle.fill  { fill: none; stroke: var(--green); stroke-width: 3;
  stroke-dasharray: 120; stroke-dashoffset: 120; stroke-linecap: round;
  transition: stroke-dashoffset 0.2s linear; }
#scroll-pct {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  font-size: 0.55rem; font-weight: 700; color: var(--green); font-family: 'Outfit',sans-serif;
}

/* ══ STİCKY DOT NAVİGASYON ══ */
#dot-nav {
  position: fixed; right: 1.5rem; top: 50%; transform: translateY(-50%);
  display: flex; flex-direction: column; gap: 12px; z-index: 7000;
}
.dot-nav-item {
  position: relative; width: 10px; height: 10px; border-radius: 50%;
  background: rgba(255,255,255,0.2); cursor: none; transition: all 0.3s;
  border: none; padding: 0;
}
.dot-nav-item.active { background: var(--green); box-shadow: 0 0 10px rgba(74,222,128,0.5); transform: scale(1.3); }
.dot-nav-item:hover { background: var(--green); transform: scale(1.2); }
.dot-nav-item::after {
  content: attr(data-label); position: absolute; right: 20px; top: 50%;
  transform: translateY(-50%); background: rgba(9,26,19,0.9); color: var(--green);
  font-size: 0.72rem; font-weight: 600; padding: 4px 10px; border-radius: 20px;
  white-space: nowrap; opacity: 0; pointer-events: none; transition: opacity 0.3s;
  border: 1px solid var(--border-glow);
}
.dot-nav-item:hover::after { opacity: 1; }
@media(max-width:768px){ #dot-nav { display: none; } }

/* ══ SECTION NUMARALANDIRMA ══ */
.sec-num {
  font-family: 'Outfit', sans-serif; font-size: clamp(5rem,10vw,9rem);
  font-weight: 800; color: transparent; -webkit-text-stroke: 1px rgba(74,222,128,0.08);
  position: absolute; left: -1rem; top: -2rem; line-height: 1;
  pointer-events: none; user-select: none; z-index: 0;
}
.section-header { position: relative; }

/* ══ BENTO GRID ══ */
.bento-section { padding: 6rem 0; }
.bento-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: auto auto;
  gap: 1.2rem; margin-top: 3rem;
}
.bento-card {
  border-radius: 24px; padding: 2rem; background: var(--surface);
  border: 1px solid var(--border); transition: all 0.4s; position: relative;
  overflow: hidden;
}
.bento-card::before {
  content: ''; position: absolute; inset: 0; opacity: 0; transition: opacity 0.4s;
  background: radial-gradient(circle at 30% 30%, rgba(74,222,128,0.06), transparent 60%);
}
.bento-card:hover { transform: translateY(-4px); border-color: var(--border-glow); }
.bento-card:hover::before { opacity: 1; }
.bento-card.wide { grid-column: span 2; }
.bento-card.tall { grid-row: span 2; }
.bento-num { font-family:'Outfit',sans-serif; font-size:3rem; font-weight:800; color:rgba(74,222,128,0.15); line-height:1; margin-bottom:0.5rem; }
.bento-icon { font-size: 2rem; color: var(--green); margin-bottom: 1rem; }
.bento-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
.bento-card p  { font-size: 0.83rem; color: var(--muted); line-height: 1.6; }
.bento-big-num { font-family:'Outfit',sans-serif; font-size: 3.5rem; font-weight: 800; color: var(--green); line-height: 1; }
.bento-big-label { font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

/* ══ SPLIT SCREEN KARŞILAŞTIRMA ══ */
.split-section { padding: 6rem 0; }
.split-wrap {
  position: relative; border-radius: 24px; overflow: hidden;
  border: 1px solid var(--border); height: 400px; cursor: none;
}
.split-left, .split-right {
  position: absolute; top: 0; bottom: 0; display: flex; align-items: center;
  justify-content: center; flex-direction: column; gap: 1rem; padding: 2.5rem;
}
.split-left  { left: 0; right: 50%; background: rgba(252,165,165,0.05); border-right: 2px solid var(--border); }
.split-right { left: 50%; right: 0; background: rgba(74,222,128,0.05); }
.split-divider {
  position: absolute; top: 0; bottom: 0; width: 4px; background: var(--green);
  left: 50%; transform: translateX(-50%); z-index: 10; cursor: col-resize;
  box-shadow: 0 0 20px rgba(74,222,128,0.4);
}
.split-handle {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 36px; height: 36px; border-radius: 50%; background: var(--green);
  display: flex; align-items: center; justify-content: center; color: #0d2319;
  font-size: 0.9rem; box-shadow: 0 0 20px rgba(74,222,128,0.5);
}
.split-title { font-family:'Outfit',sans-serif; font-size:1.3rem; font-weight:800; }
.split-left .split-title { color: var(--red); }
.split-right .split-title { color: var(--green); }
.split-item { font-size: 0.88rem; color: var(--muted); display: flex; align-items: center; gap: 0.6rem; }
.split-item i { font-size: 1.1rem; }
.split-left .split-item i { color: var(--red); }
.split-right .split-item i { color: var(--green); }

/* ══ CONFETTI ══ */
.confetti-piece {
  position: fixed; width: 8px; height: 8px; pointer-events: none;
  z-index: 99999; animation: confettiFall linear forwards;
  border-radius: 2px;
}
@keyframes confettiFall {
  0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

/* ══ GLITCH ══ */
.glitch { position: relative; }
.glitch:hover::before, .glitch:hover::after {
  content: attr(data-text); position: absolute; top: 0; left: 0; width: 100%;
  -webkit-text-fill-color: transparent; -webkit-background-clip: text;
}
.glitch:hover::before {
  background: linear-gradient(90deg,#ff0000,transparent);
  animation: glitch1 0.3s steps(2) infinite; clip-path: polygon(0 0,100% 0,100% 35%,0 35%);
}
.glitch:hover::after {
  background: linear-gradient(90deg,transparent,#00ffff);
  animation: glitch2 0.3s steps(2) infinite; clip-path: polygon(0 65%,100% 65%,100% 100%,0 100%);
}
@keyframes glitch1 { 0%{transform:translate(-2px,0)} 50%{transform:translate(2px,0)} 100%{transform:translate(-1px,0)} }
@keyframes glitch2 { 0%{transform:translate(2px,0)}  50%{transform:translate(-2px,0)} 100%{transform:translate(1px,0)} }

/* ══ SCRAMBLE TEXT ══ */
[data-scramble] { display: inline-block; }

/* ══ VARIABLE FONT PULSE ══ */
.var-pulse { animation: varPulse 3s ease-in-out infinite; }
@keyframes varPulse {
  0%,100% { font-weight: 800; letter-spacing: -2px; }
  50%     { font-weight: 300; letter-spacing: 2px; }
}

/* responsive */
@media(max-width:768px){
  .bento-grid { grid-template-columns: 1fr 1fr; }
  .bento-card.wide { grid-column: span 2; }
  .bento-card.tall { grid-row: span 1; }
  .split-wrap { height: 500px; }
  .split-left, .split-right { padding: 1.5rem; }
  #scroll-ring { display: none; }
  .sec-num { font-size: 4rem; }
}
@media(max-width:480px){
  .bento-grid { grid-template-columns: 1fr; }
  .bento-card.wide { grid-column: span 1; }
}
</style>
