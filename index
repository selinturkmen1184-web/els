/* DİL */
function setLang(l){
  lang=l;
  document.documentElement.lang=l;
  const t=T[l];
  ['langTR','langEN','mobileLangTR','mobileLangEN'].forEach(id=>{
    const el=document.getElementById(id);
    if(el)el.classList.toggle('active',id.endsWith(l.toUpperCase()));
  });
  document.querySelectorAll('[data-i18n]').forEach(el=>{
    const k=el.dataset.i18n;
    if(t[k]!==undefined)el.textContent=t[k];
  });
  const ct=document.getElementById('ctaTitle');
  if(ct)ct.innerHTML=(t['cta.title']||'').replace(/\n/g,'<br>');
  const db=document.getElementById('demoBtn');
  if(db)db.innerHTML=(l==='tr'?'Demo Al':'Get Demo')+' <i class="ph-fill ph-play-circle"></i>';
  const hb=document.getElementById('heroBtn1');
  if(hb)hb.innerHTML=t['hero.btn1']+' <i class="ph ph-arrow-right"></i>';
  const cb=document.getElementById('ctaBtn1');
  if(cb)cb.innerHTML=t['cta.btn1']+' <i class="ph ph-arrow-right"></i>';
  const ni=document.getElementById('nlInput');
  if(ni)ni.placeholder=t['nl.ph'];
  const pl=document.querySelector('#preloader p');
  if(pl)pl.textContent=t['preloader.text'];
  const ck=document.querySelector('#cookie-banner p');
  if(ck)ck.innerHTML=t['cookie.text']+' <a href="#">'+( l==='tr'?'Gizlilik Politikası':'Privacy Policy')+'</a>';
  updateSim();
  document.title=l==='tr'?'ELLS — Otonom Çay Bahçesi Robotu':'ELLS — Autonomous Tea Garden Robot';
  try{localStorage.setItem('ells-lang',l);}catch(e){}
}

