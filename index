const scrollImg = document.getElementById('scrollRobotImg');
const scrollStepEls = document.querySelectorAll('.scroll-step');
const scrollSection = document.querySelector('.scroll-robot-section');

if (scrollSection && scrollImg) {
  window.addEventListener('scroll', () => {
    const rect = scrollSection.getBoundingClientRect();
    const progress = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight * 0.5)));
    const rotation = progress * 360;
    scrollImg.style.transform = `rotate(${rotation}deg)`;

    // Adım aktivasyonu
    const step = Math.floor(progress * scrollStepEls.length);
    scrollStepEls.forEach((el, i) => el.classList.toggle('active', i === Math.min(step, scrollStepEls.length - 1)));
  }, { passive: true });
}

