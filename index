const scene3d = document.getElementById('robot3dScene');
const card3d  = document.getElementById('robot3dCard');
const glow3d  = document.getElementById('robot3dGlow');
let isFlipped = false;
let isDragging = false;
let startX = 0, startY = 0;
let rotX = 0, rotY = 0;

if (scene3d && card3d) {
  scene3d.addEventListener('mousemove', e => {
    if (isFlipped) return;
    const rect = scene3d.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top  + rect.height / 2;
    const dx = (e.clientX - cx) / (rect.width  / 2);
    const dy = (e.clientY - cy) / (rect.height / 2);
    const tiltX = -dy * 18;
    const tiltY =  dx * 18;
    card3d.style.transform = `rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
    const mx = ((e.clientX - rect.left) / rect.width  * 100).toFixed(1);
    const my = ((e.clientY - rect.top)  / rect.height * 100).toFixed(1);
    if (glow3d) { glow3d.style.setProperty('--mx', mx+'%'); glow3d.style.setProperty('--my', my+'%'); }
  });

  scene3d.addEventListener('mouseleave', () => {
    if (!isFlipped) {
      card3d.style.transition = 'transform 0.6s cubic-bezier(0.34,1.56,0.64,1)';
      card3d.style.transform = 'rotateX(0deg) rotateY(0deg)';
      setTimeout(() => card3d.style.transition = 'transform 0.1s ease', 600);
    }
  });

  // Touch drag support
  scene3d.addEventListener('touchstart', e => {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    isDragging = true;
  }, {passive:true});

  scene3d.addEventListener('touchmove', e => {
    if (!isDragging || isFlipped) return;
    const dx = (e.touches[0].clientX - startX) / 5;
    const dy = (e.touches[0].clientY - startY) / 5;
    card3d.style.transform = `rotateX(${-dy}deg) rotateY(${dx}deg)`;
  }, {passive:true});

  scene3d.addEventListener('touchend', () => {
    isDragging = false;
    if (!isFlipped) {
      card3d.style.transition = 'transform 0.5s ease';
      card3d.style.transform = 'rotateX(0deg) rotateY(0deg)';
    }
  });
}

function flipRobot3D() {
