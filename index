   MATRİX YAĞMUR
════════════════════════════════ */
const matrixCanvas = document.getElementById('matrix-canvas');
let matrixActive = false;
let matrixAnimId = null;

function initMatrix() {
  const ctx = matrixCanvas.getContext('2d');
  matrixCanvas.width  = window.innerWidth;
  matrixCanvas.height = window.innerHeight;
  const cols = Math.floor(matrixCanvas.width / 20);
  const drops = Array(cols).fill(1);
  const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノ01010111ELLS葉茶畑機械人工知能'.split('');

  function draw() {
    ctx.fillStyle = 'rgba(0,0,0,0.04)';
    ctx.fillRect(0, 0, matrixCanvas.width, matrixCanvas.height);
    ctx.fillStyle = '#4ade80';
    ctx.font = '14px monospace';
    drops.forEach((y, i) => {
      const ch = chars[Math.floor(Math.random() * chars.length)];
      ctx.fillStyle = y === 1 ? '#a7f3d0' : '#4ade80';
      ctx.fillText(ch, i * 20, y * 20);
      if (y * 20 > matrixCanvas.height && Math.random() > 0.975) drops[i] = 0;
      drops[i]++;
    });
    matrixAnimId = requestAnimationFrame(draw);
  }
  return draw;
}

function toggleMatrix() {
  matrixActive = !matrixActive;
  const btn = document.getElementById('matrix-toggle');
  const icon = document.getElementById('matrix-icon');
  if (matrixActive) {
    matrixCanvas.classList.add('active');
    btn.classList.add('active');
    icon.className = 'ph ph-x';
    const draw = initMatrix();
    draw();
    showToast('🖥️ Matrix modu aktif', 'info');
  } else {
    matrixCanvas.classList.remove('active');
    btn.classList.remove('active');
    icon.className = 'ph ph-code';
    if (matrixAnimId) cancelAnimationFrame(matrixAnimId);
    const ctx = matrixCanvas.getContext('2d');
    ctx.clearRect(0, 0, matrixCanvas.width, matrixCanvas.height);
    showToast('Matrix modu kapatıldı', 'info');
  }
}

window.addEventListener('resize', () => {
  if (matrixActive && matrixCanvas) {
    matrixCanvas.width  = window.innerWidth;
    matrixCanvas.height = window.innerHeight;
  }
});


const cursor = document.getElementById('cursor');
const cursorRing = document.getElementById('cursor-ring');
const trails = [];
const TRAIL_COUNT = 6;

// Trail noktaları oluştur
for (let i = 0; i < TRAIL_COUNT; i++) {
  const t = document.createElement('div');
  t.className = 'cursor-trail';
  t.style.opacity = (1 - i / TRAIL_COUNT) * 0.5;
  t.style.width = t.style.height = (5 - i * 0.5) + 'px';
  document.body.appendChild(t);
  trails.push({ el: t, x: 0, y: 0 });
}

let mouseX = 0, mouseY = 0;
let ringX = 0, ringY = 0;
const trailPositions = Array(TRAIL_COUNT).fill({ x: 0, y: 0 }).map(() => ({ x: 0, y: 0 }));

document.addEventListener('mousemove', e => {
  mouseX = e.clientX;
  mouseY = e.clientY;
  cursor.style.left = mouseX + 'px';
  cursor.style.top = mouseY + 'px';
});

// Smooth ring & trail follow
function animateCursor() {
  ringX += (mouseX - ringX) * 0.12;
  ringY += (mouseY - ringY) * 0.12;
  cursorRing.style.left = ringX + 'px';
  cursorRing.style.top = ringY + 'px';

  // Trail lag
  trailPositions[0].x += (mouseX - trailPositions[0].x) * 0.25;
  trailPositions[0].y += (mouseY - trailPositions[0].y) * 0.25;
  for (let i = 1; i < TRAIL_COUNT; i++) {
    trailPositions[i].x += (trailPositions[i-1].x - trailPositions[i].x) * 0.3;
    trailPositions[i].y += (trailPositions[i-1].y - trailPositions[i].y) * 0.3;
    trails[i].el.style.left = trailPositions[i].x + 'px';
    trails[i].el.style.top = trailPositions[i].y + 'px';
  }
  requestAnimationFrame(animateCursor);
}
animateCursor();

