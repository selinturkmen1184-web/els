function closeMobile(){document.getElementById('mobileMenu').classList.remove('open');document.getElementById('hamburger').classList.remove('open');}

/* REVEAL */
const ro=new IntersectionObserver((entries,obs)=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('active');obs.unobserve(e.target);}});
},{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));
setTimeout(()=>{document.querySelectorAll('.reveal').forEach(el=>{if(el.getBoundingClientRect().top<window.innerHeight)el.classList.add('active');});},100);

/* COUNT-UP */
const co=new IntersectionObserver((entries,obs)=>{
  entries.forEach(e=>{
    if(!e.isIntersecting)return;
    const el=e.target,target=parseInt(el.dataset.target);
    let cur=0;const step=Math.max(1,Math.floor(target/60));
    const timer=setInterval(()=>{cur=Math.min(cur+step,target);el.textContent=cur+'%';if(cur>=target)clearInterval(timer);},25);
    obs.unobserve(el);
  });
},{threshold:0.5});
document.querySelectorAll('.count-up').forEach(el=>co.observe(el));

/* SİMÜLATÖR */
function updateSim(){
  const aEl=document.getElementById('areaSlider');
  const rEl=document.getElementById('robotSlider');
  const hEl=document.getElementById('hoursSlider');
  if(!aEl||!rEl||!hEl)return;
  const area=parseInt(aEl.value),robots=parseInt(rEl.value),hours=parseInt(hEl.value);
  const t=T[lang]||T.tr;
  document.getElementById('areaVal').textContent=area+' da';
  document.getElementById('robotVal').textContent=robots+' '+(t['sim.units']||'birim');
  document.getElementById('hoursVal').textContent=hours+' '+(t['sim.hrs']||'saat');
  aEl.style.setProperty('--val',((area-5)/(500-5)*100)+'%');
  rEl.style.setProperty('--val',((robots-1)/(20-1)*100)+'%');
  hEl.style.setProperty('--val',((hours-4)/(24-4)*100)+'%');
  const dy=Math.round(robots*hours*15);
  document.getElementById('yieldResult').textContent=dy.toLocaleString()+' kg';
  document.getElementById('savingResult').textContent='₺'+(dy*12).toLocaleString();
  document.getElementById('seasonResult').textContent=(dy*120).toLocaleString()+' kg';
  const co2=((dy*120)*0.00003).toFixed(1);
  document.getElementById('co2Result').textContent=co2+' ton';
}
window.addEventListener('DOMContentLoaded',updateSim);

