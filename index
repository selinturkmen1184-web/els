/* CHAT */
let chatOpen=false;
function toggleChat(){
  chatOpen=!chatOpen;
  document.getElementById('chat-modal').classList.toggle('open',chatOpen);
  document.getElementById('chat-badge').style.display='none';
}
function addBubble(text,type){
  const body=document.getElementById('chat-body');
  const div=document.createElement('div');
  div.className='chat-bubble '+type;
  div.textContent=text;
  body.appendChild(div);
  body.scrollTop=body.scrollHeight;
}
function sendQuick(msg){
  document.getElementById('chat-quick').style.display='none';
  addBubble(msg,'user');
  setTimeout(()=>{
    const t=T[lang];
    let reply=t['chat.default'];
    if(msg.includes('Fiyat')||msg.includes('price')||msg.includes('pricing'))reply=t['chat.price'];
    else if(msg.includes('Demo')||msg.includes('demo'))reply=t['chat.demo'];
    else if(msg.includes('Teknik')||msg.includes('spec')||msg.includes('Technical'))reply=t['chat.specs'];
    else if(msg.includes('Sipariş')||msg.includes('order'))reply=t['chat.order'];
    addBubble(reply,'bot');
  },600);
}
function sendChat(){
  const input=document.getElementById('chat-input');
  const msg=input.value.trim();
  if(!msg)return;
  addBubble(msg,'user');
  input.value='';
  document.getElementById('chat-quick').style.display='none';
  setTimeout(()=>addBubble(T[lang]['chat.default'],'bot'),700);
}

