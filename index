  const s = document.getElementById('robot3dScene');
  const btn = document.querySelector('.flip-btn span');
  if (!s) return;
  s.classList.toggle('flipped', isFlipped);
  if (card3d) { card3d.style.transition = 'transform 0.7s cubic-bezier(0.4,0,0.2,1)'; }
