/* ════ AI YAPRAK TESPİT ════ */
let leafMode='scan', leafAnimId=null, leafCount=0;
const leafColors={scan:'#4ade80',detect:'#fbbf24',harvest:'#f87171'};

function setLeafMode(mode){
  leafMode=mode;
  ['scan','detect','harvest'].forEach((m,i)=>{
    document.getElementById('leafBtn'+(i+1)).classList.toggle('active',m===mode);
  });
  if(leafAnimId) cancelAnimationFrame(leafAnimId);
  leafCount=0;
  drawLeafCanvas();
}

function drawLeafCanvas(){
  const canvas=document.getElementById('leafCanvas');
  if(!canvas) return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const dots=[];
  for(let i=0;i<18;i++) dots.push({x:Math.random()*W,y:Math.random()*H,r:6+Math.random()*14,detected:Math.random()>0.3,conf:0.7+Math.random()*0.3,pulse:Math.random()*Math.PI*2});

  let frame=0;
  function animate(){
    ctx.fillStyle='rgba(10,26,16,0.85)';
    ctx.fillRect(0,0,W,H);

    // Grid
    ctx.strokeStyle='rgba(74,222,128,0.06)';
    ctx.lineWidth=1;
    for(let x=0;x<W;x+=30){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(let y=0;y<H;y+=30){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    // Scan line
    if(leafMode==='scan'){
      const scanY=(frame*1.5)%H;
      const grad=ctx.createLinearGradient(0,scanY-20,0,scanY+20);
      grad.addColorStop(0,'rgba(74,222,128,0)');
      grad.addColorStop(0.5,'rgba(74,222,128,0.3)');
      grad.addColorStop(1,'rgba(74,222,128,0)');
      ctx.fillStyle=grad;
      ctx.fillRect(0,scanY-20,W,40);
    }

    // Dots (yapraklar)
    let det=0;
    dots.forEach(d=>{
      d.pulse+=0.05;
      const inScanRange=leafMode!=='scan'||Math.abs((frame*1.5)%H-d.y)<60;
      if(!inScanRange&&leafMode==='scan'){return;}

      const col=leafColors[leafMode];
      if(d.detected){
        det++;
        // Bounding box
        ctx.strokeStyle=col;
        ctx.lineWidth=1.5;
        ctx.globalAlpha=0.8+Math.sin(d.pulse)*0.2;
        ctx.strokeRect(d.x-d.r-4,d.y-d.r-4,d.r*2+8,d.r*2+8);
        // Corner marks
        ctx.lineWidth=2.5;
        [[d.x-d.r-4,d.y-d.r-4],[d.x+d.r+4,d.y-d.r-4],[d.x-d.r-4,d.y+d.r+4],[d.x+d.r+4,d.y+d.r+4]].forEach(([cx,cy],ci)=>{
          ctx.beginPath();
          ctx.moveTo(cx+(ci%2===0?8:-8),cy);ctx.lineTo(cx,cy);ctx.lineTo(cx,cy+(ci<2?8:-8));
          ctx.stroke();
        });
        // Label
        ctx.globalAlpha=1;
        ctx.fillStyle=col;
        ctx.font='bold 9px monospace';
        ctx.fillText((d.conf*100).toFixed(1)+'%',d.x-d.r,d.y-d.r-8);
        // Pulse circle
        ctx.strokeStyle=col;
        ctx.lineWidth=1;
        ctx.globalAlpha=0.3*Math.max(0,Math.sin(d.pulse));
        ctx.beginPath();ctx.arc(d.x,d.y,(d.r+10)+Math.sin(d.pulse)*5,0,Math.PI*2);ctx.stroke();
      }

      // Leaf circle
      ctx.globalAlpha=d.detected?0.9:0.3;
      ctx.fillStyle=d.detected?col:'rgba(255,255,255,0.3)';
      ctx.beginPath();ctx.arc(d.x,d.y,d.r*0.7,0,Math.PI*2);ctx.fill();
      ctx.globalAlpha=1;
    });

    // HUD
    ctx.fillStyle='rgba(74,222,128,0.9)';
    ctx.font='bold 10px monospace';
    ctx.fillText('ELLS AI v2.4 — '+leafMode.toUpperCase(),10,18);
    ctx.fillStyle='rgba(167,240,195,0.6)';
    ctx.fillText('FRAME: '+String(frame).padStart(5,'0'),10,32);
    ctx.fillText('DET: '+det+'/'+dots.length,10,46);

    // Crosshair
    const cx2=W/2,cy2=H/2;
    ctx.strokeStyle='rgba(74,222,128,0.3)';ctx.lineWidth=1;
    ctx.setLineDash([4,4]);
    ctx.beginPath();ctx.moveTo(cx2,0);ctx.lineTo(cx2,H);ctx.moveTo(0,cy2);ctx.lineTo(W,cy2);ctx.stroke();
    ctx.setLineDash([]);

    leafCount=det;
    const el=document.getElementById('leafCount');
    const bar=document.getElementById('leafBar');
    if(el) el.textContent=leafCount;
    if(bar) bar.style.width=(leafCount/dots.length*100)+'%';

    frame++;
    leafAnimId=requestAnimationFrame(animate);
  }
  animate();
}

/* Start leaf canvas when in view */
const leafObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting&&!leafAnimId) drawLeafCanvas();
    else if(!e.isIntersecting&&leafAnimId){cancelAnimationFrame(leafAnimId);leafAnimId=null;}
  });
},{threshold:0.3});
window.addEventListener('DOMContentLoaded',()=>{
  const lc=document.getElementById('leafCanvas');
  if(lc) leafObs.observe(lc);
});

