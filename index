const liveStart={kg:284750,co2:8.5,hrs:19230};
const liveRate={kg:0.8,co2:0.000024,hrs:0.05};
function updateLive(){
  const now=Date.now();
  const elapsed=(now-startTime)/1000;
  const kg=Math.round(liveStart.kg+elapsed*liveRate.kg);
  const co2=(liveStart.co2+elapsed*liveRate.co2).toFixed(2);
  const hrs=Math.round(liveStart.hrs+elapsed*liveRate.hrs);
  const co2El=document.getElementById('live-co2');
  if(co2El)co2El.textContent=co2;
}
const startTime=Date.now();
setInterval(updateLive,500);
updateLive();

